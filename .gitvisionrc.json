{
  "$schema": "https://raw.githubusercontent.com/git-vision/git-vision/main/schema.json",
  "format": "terminal",
  "top": 10,
  "ignore": [
    ".next/**",
    "node_modules/**",
    "dist/**",
    "out/**",
    "coverage/**",
    "build/**",
    "*.min.js",
    "*.min.css"
  ],
  "thresholds": {
    "busFactor": {
      "ownershipThreshold": 0.8
    },
    "coupling": {
      "minSharedCommits": 5,
      "minCouplingDegree": 0.3
    },
    "healthScore": {
      "critical": 40
    }
  },
  "blame": {
    "enabled": false,
    "maxFiles": 50
  },
  "monorepo": {
    "enabled": false
  }
}
